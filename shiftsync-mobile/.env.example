# shiftsync-mobile/.env.example
# -----------------------------------------------------------------------------
# On a new machine:
#   1. Copy this file to .env  (same folder)
#        copy .env.example .env          # Windows cmd
#        cp .env.example .env            # macOS/Linux / Git Bash
#   2. Point EXPO_PUBLIC_API_URL at your gateway (this PC or LAN IP)
#   3. Mock vs live API is in code: src/api/mode.ts → USE_MOCK_API
#        true  = no backend needed
#        false = calls EXPO_PUBLIC_API_URL
#   4. npm install && npm run start
# -----------------------------------------------------------------------------

# Gateway base URL (no trailing slash)
# Emulator/simulator: http://localhost:8080
# Physical phone:     http://<your-computer-lan-ip>:8080
EXPO_PUBLIC_API_URL=http://localhost:8080
