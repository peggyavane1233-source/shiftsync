# shiftsync-backend/.env.example
# Copy to .env. Never commit .env.
#
# From Supabase Dashboard:
#   PROJECT_REF  → URL app.supabase.com/project/<ref>  OR  Settings → General
#   REGION       → Settings → General (e.g. eu-west-1, us-east-1) — used in aws-0-<region>
#   DB password  → Settings → Database → Database password
#                  (NOT dashboard login, NOT anon/publishable, NOT sb_secret_)
# PostGIS is NOT required — underground live GIS / geofence is disabled.

SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_REGION=eu-west-1
SUPABASE_DB_PASSWORD=your_database_password_from_settings_database

# Built JDBC (pooler session mode :5432 — not direct db.<ref>, not :6543 transaction mode)
DB_URL=jdbc:postgresql://aws-0-${SUPABASE_REGION}.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.${SUPABASE_PROJECT_REF}
DB_PASSWORD=${SUPABASE_DB_PASSWORD}
DB_USER=${DB_USERNAME}

HIKARI_MAX_POOL_SIZE=3
HIKARI_MIN_IDLE=1

# Enable for ONE service at a time on first boot (shared DB + Flyway advisory locks)
FLYWAY_ENABLED=false

# REST keys (apps / supabase-js) — separate from JDBC
SUPABASE_URL=https://${SUPABASE_PROJECT_REF}.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_ANON_KEY=eyJ...

JWT_PRIVATE_KEY_PATH=classpath:keys/private.pem
JWT_PUBLIC_KEY_PATH=classpath:keys/public.pem
KAFKA_BROKERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
