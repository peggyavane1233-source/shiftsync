# shiftsync-backend/.env.example
# -----------------------------------------------------------------------------
# On a new machine:
#   1. Copy this file to .env  (same folder)
#        copy .env.example .env          # Windows cmd
#        cp .env.example .env            # macOS/Linux / Git Bash
#   2. Fill every value below from Supabase Dashboard
#   3. Run schema in Supabase SQL Editor:
#        docs/supabase/V1__schema.sql then V2__seed_dev.sql
#   4. Start Redis on :6379, then:  .\start-dev.ps1
# -----------------------------------------------------------------------------
# Never commit .env (secrets). This .env.example is safe to commit.
#
# Supabase Dashboard → Project Settings:
#   PROJECT_REF   → General → Reference ID
#   REGION        → General (e.g. eu-north-1) — used in aws-0-<REGION>
#   DB password   → Database → Database password
#                   (NOT dashboard login, NOT anon key, NOT sb_secret_)
#   API keys      → API → anon / service_role (or publishable / secret)
#
# PowerShell does NOT expand ${VAR} in .env — paste concrete values.

SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_REGION=eu-north-1
SUPABASE_DB_PASSWORD=your_database_password

# Pooler session mode (:5432). Replace REGION and PROJECT_REF literally.
DB_URL=jdbc:postgresql://aws-0-eu-north-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.your_project_ref
DB_PASSWORD=your_database_password
DB_USER=postgres.your_project_ref

HIKARI_MAX_POOL_SIZE=3
HIKARI_MIN_IDLE=1

# Keep false when all services start together (shared DB + Flyway locks).
# Set true for ONE service only on first empty DB if you prefer Flyway over SQL Editor.
FLYWAY_ENABLED=false

SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_ANON_KEY=eyJ...

JWT_PRIVATE_KEY_PATH=classpath:keys/private.pem
JWT_PUBLIC_KEY_PATH=classpath:keys/public.pem
KAFKA_BROKERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
